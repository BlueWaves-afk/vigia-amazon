# Environment Variables (Copy to .env.local and fill in values)

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# API Gateway
NEXT_PUBLIC_API_URL=

# Amazon Location Service
NEXT_PUBLIC_MAP_NAME=
NEXT_PUBLIC_ROUTE_CALCULATOR_NAME=

# Bedrock Agent
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# DynamoDB Tables
HAZARDS_TABLE_NAME=
COOLDOWN_TABLE_NAME=
TRACES_TABLE_NAME=
LEDGER_TABLE_NAME=

# Secrets Manager
PUBLIC_KEY_SECRET_ARN=

# Feature Flags
COST_LIMIT_FLAG=false
